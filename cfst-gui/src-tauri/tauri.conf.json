{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "CFST GUI",
  "version": "0.1.0",
  "identifier": "com.cfst-gui.app",
  "build": {
    "frontendDist": "dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CFST GUI - CloudflareSpeedTest 优选工具",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }}
